<?xml version="1.0" ?>
<sdf version="1.10">
  <model name='robot' canonical_link='body'>

    <!-- ===== BODY ===== -->
    <link name='body'>
      <pose relative_to='__model__'>0.5 0 0.5 0 0 0</pose>
      <inertial>
        <mass>50</mass>
        <inertia>
          <ixx>3.708333</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>7.041667</iyy><iyz>0</iyz>
          <izz>8.666667</izz>
        </inertia>
      </inertial>
      <visual name='visual'>
        <geometry><box><size>1.2 0.8 0.5</size></box></geometry>
        <material>
          <ambient>0.1 0.1 0.6 1</ambient>
          <diffuse>0.1 0.1 0.9 1</diffuse>
        </material>
      </visual>
      <collision name='collision'>
        <geometry><box><size>1.2 0.8 0.5</size></box></geometry>
      </collision>
    </link>

    <!-- ===== WHEELS ===== -->
    <link name='front_left_wheel'>
      <pose relative_to="body">0.40 0.44 -0.25 -1.5707 0 0</pose>
      <inertial>
        <mass>3</mass>
        <inertia><ixx>0.0316</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.0316</iyy><iyz>0</iyz><izz>0.06</izz></inertia>
      </inertial>
      <visual name='visual'>
        <geometry><cylinder><radius>0.2</radius><length>0.08</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.2</radius><length>0.08</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
    </link>

    <link name='front_right_wheel'>
      <pose relative_to="body">0.40 -0.44 -0.25 -1.5707 0 0</pose>
      <inertial>
        <mass>3</mass>
        <inertia><ixx>0.0316</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.0316</iyy><iyz>0</iyz><izz>0.06</izz></inertia>
      </inertial>
      <visual name='visual'>
        <geometry><cylinder><radius>0.2</radius><length>0.08</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.2</radius><length>0.08</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
    </link>

    <link name='back_left_wheel'>
      <pose relative_to="body">-0.40 0.44 -0.25 -1.5707 0 0</pose>
      <inertial>
        <mass>3</mass>
        <inertia><ixx>0.0316</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.0316</iyy><iyz>0</iyz><izz>0.06</izz></inertia>
      </inertial>
      <visual name='visual'>
        <geometry><cylinder><radius>0.2</radius><length>0.08</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.2</radius><length>0.08</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
    </link>

    <link name='back_right_wheel'>
      <pose relative_to="body">-0.40 -0.44 -0.25 -1.5707 0 0</pose>
      <inertial>
        <mass>3</mass>
        <inertia><ixx>0.0316</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.0316</iyy><iyz>0</iyz><izz>0.06</izz></inertia>
      </inertial>
      <visual name='visual'>
        <geometry><cylinder><radius>0.2</radius><length>0.08</length></cylinder></geometry>
        <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
      </visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.2</radius><length>0.08</length></cylinder></geometry>
        <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface>
      </collision>
    </link>

    <!-- ===== CAMERA MAST ===== -->
    <link name='desk_for_depth'>
      <pose relative_to='body'>0.55 0 0.5 0 0 0</pose>
      <inertial>
        <mass>2.5</mass>
        <inertia><ixx>0.1034</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.1034</iyy><iyz>0</iyz><izz>0.00267</izz></inertia>
      </inertial>
      <visual name='visual'>
        <geometry><box><size>0.08 0.08 0.7</size></box></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
      </visual>
      <collision name='collision'>
        <geometry><box><size>0.08 0.08 0.7</size></box></geometry>
      </collision>
    </link>

    <!-- ===== RGBD CAMERA ===== -->
    <link name='RGBD_camera'>
      <pose relative_to='desk_for_depth'>0.05 0 0.33 0 1.1 0</pose>
      <inertial>
        <mass>0.145</mass>
        <inertia><ixx>0.0000604</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.0000604</iyy><iyz>0</iyz><izz>0.0000604</izz></inertia>
      </inertial>
      <visual name='visual'>
        <geometry><box><size>0.05 0.1 0.04</size></box></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>
      <collision name='collision'>
        <geometry><box><size>0.05 0.1 0.04</size></box></geometry>
      </collision>
      <sensor name="rgbd_sensor" type="rgbd_camera">
        <topic>/rgbd/image</topic>
        <camera>
          <horizontal_fov>1.5</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.1</near><far>10.0</far></clip>
          <noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise>
        </camera>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
      </sensor>
    </link>

    <!-- ===== NAV CAMERA ===== -->
    <link name='nav_camera'>
      <pose relative_to='body'>0.6 0 0 0 0.45 0</pose>
      <inertial>
        <mass>0.145</mass>
        <inertia><ixx>0.0000604</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.0000604</iyy><iyz>0</iyz><izz>0.0000604</izz></inertia>
      </inertial>
      <visual name='visual'>
        <geometry><box><size>0.05 0.1 0.04</size></box></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material>
      </visual>
      <collision name='collision'>
        <geometry><box><size>0.05 0.1 0.04</size></box></geometry>
      </collision>
      <sensor name="nav_sensor" type="camera">
        <topic>/camera/image</topic>
        <camera>
          <horizontal_fov>1.0</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.1</near><far>100</far></clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>30</update_rate>
      </sensor>
    </link>

    <!-- ===== 2D LIDAR ===== -->
    <link name='lidar_link'>
      <pose relative_to='body'>0 0 0.32 0 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia><ixx>0.0002</ixx><ixy>0</ixy><ixz>0</ixz>
                 <iyy>0.0002</iyy><iyz>0</iyz><izz>0.0003</izz></inertia>
      </inertial>
      <visual name='visual'>
        <geometry><cylinder><radius>0.055</radius><length>0.07</length></cylinder></geometry>
        <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>
      <collision name='collision'>
        <geometry><cylinder><radius>0.055</radius><length>0.07</length></cylinder></geometry>
      </collision>
      <sensor name="lidar_sensor" type="gpu_lidar">
        <topic>/scan</topic>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159265</min_angle>
              <max_angle>3.14159265</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.15</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
        </lidar>
        <always_on>true</always_on>
        <visualize>false</visualize>
      </sensor>
    </link>

    <!-- ===== JOINTS ===== -->
    <joint name='front_left_wheel_joint' type='revolute'>
      <pose relative_to='front_left_wheel'/>
      <parent>body</parent><child>front_left_wheel</child>
      <axis>
        <xyz expressed_in='__model__'>0 1 0</xyz>
        <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
      </axis>
    </joint>
    <joint name='front_right_wheel_joint' type='revolute'>
      <pose relative_to='front_right_wheel'/>
      <parent>body</parent><child>front_right_wheel</child>
      <axis>
        <xyz expressed_in='__model__'>0 1 0</xyz>
        <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
      </axis>
    </joint>
    <joint name='back_left_wheel_joint' type='revolute'>
      <pose relative_to='back_left_wheel'/>
      <parent>body</parent><child>back_left_wheel</child>
      <axis>
        <xyz expressed_in='__model__'>0 1 0</xyz>
        <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
      </axis>
    </joint>
    <joint name='back_right_wheel_joint' type='revolute'>
      <pose relative_to='back_right_wheel'/>
      <parent>body</parent><child>back_right_wheel</child>
      <axis>
        <xyz expressed_in='__model__'>0 1 0</xyz>
        <limit><lower>-1.79769e+308</lower><upper>1.79769e+308</upper></limit>
      </axis>
    </joint>
    <joint name="desk_for_depth_joint" type="fixed">
      <parent>body</parent><child>desk_for_depth</child>
    </joint>
    <joint name="RGBD_camera_joint" type="fixed">
      <parent>desk_for_depth</parent><child>RGBD_camera</child>
    </joint>
    <joint name="nav_camera_joint" type="fixed">
      <parent>body</parent><child>nav_camera</child>
    </joint>
    <joint name="lidar_joint" type="fixed">
      <parent>body</parent><child>lidar_link</child>
    </joint>

    <!-- ===== PLUGINS ===== -->

    <!--
      КЛЮЧЕВОЕ ИСПРАВЛЕНИЕ: топики с ведущим / — абсолютные пути.
      Без / Gazebo добавляет /model/robot/ префикс → bridge не находит топик.
    -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>back_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>back_right_wheel_joint</right_joint>
      <wheel_separation>0.88</wheel_separation>
      <wheel_radius>0.2</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <max_linear_velocity>1.5</max_linear_velocity>
      <min_linear_velocity>-1.5</min_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>

  </model>
</sdf>

      <link name="link">
        <visual name="body"><pose>0 0 0.13 0 0 0</pose>
          <geometry><cylinder><radius>0.038</radius><length>0.26</length></cylinder></geometry>
          <material><ambient>0.15 0.55 0.15 0.28</ambient><diffuse>0.20 0.70 0.20 0.28</diffuse>
            <specular>0.9 0.9 0.9 1.0</specular></material></visual>
        <visual name="neck"><pose>0 0 0.278 0 0 0</pose>
          <geometry><cylinder><radius>0.018</radius><length>0.06</length></cylinder></geometry>
          <material><ambient>0.15 0.55 0.15 0.28</ambient><diffuse>0.20 0.70 0.20 0.28</diffuse>
            <specular>0.9 0.9 0.9 1.0</specular></material></visual>
        <collision name="c"><pose>0 0 0.15 0 0 0</pose>
          <geometry><cylinder><radius>0.038</radius><length>0.31</length></cylinder></geometry></collision>
      </link></model>


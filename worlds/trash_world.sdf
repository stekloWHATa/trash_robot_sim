    <!-- ── БЫЧКИ СИГАРЕТНЫЕ — лежат на полу ─────────────────────────
         Тело: жёлто-коричневый цилиндр (табак)
         Фильтр: оранжевый торец
         Размер: r=0.005м, L=0.065м                                  -->
    <model name="cig_butt_1"><static>true</static><pose> 3.5  7.5 0.005 1.5707963 0 0.8</pose>

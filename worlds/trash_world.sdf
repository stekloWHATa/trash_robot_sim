          <material><ambient>0.05 0.45 0.05 0.85</ambient><diffuse>0.08 0.6 0.08 0.85</diffuse></material>
        </visual>
        <visual name="cap">
          <pose>0 0 0.155 0 0 0</pose>
          <geometry><cylinder><radius>0.02</radius><length>0.012</length></cylinder></geometry>
          <material><ambient>0.6 0.3 0.05 1</ambient><diffuse>0.8 0.4 0.05 1</diffuse></material>
        </visual>
        <collision name="col">

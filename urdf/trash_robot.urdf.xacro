<?xml version="1.0"?>
<!--
  trash_robot.urdf.xacro — ЗЕРКАЛО only_robot.sdf
  Имена ссылок, джоинтов и смещения взяты напрямую из SDF,
  чтобы robot_state_publisher публиковал правильное TF-дерево.

  Дерево:
    base_link (= body в SDF, canonical_link)
    ├── front_left_wheel   [revolute, front_left_wheel_joint]
    ├── front_right_wheel  [revolute, front_right_wheel_joint]
    ├── back_left_wheel    [revolute, back_left_wheel_joint]
    ├── back_right_wheel   [revolute, back_right_wheel_joint]
    ├── desk_for_depth     [fixed,    desk_for_depth_joint]
    │   └── RGBD_camera    [fixed,    RGBD_camera_joint]
    ├── nav_camera         [fixed,    nav_camera_joint]
    └── lidar_link         [fixed,    lidar_joint]
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="trash_robot">

  <!-- ===== ТЕЛО (SDF body: 1.2×0.8×0.5м, масса 50кг) ===== -->
  <link name="base_link">
    <visual>
      <geometry><box size="1.2 0.8 0.5"/></geometry>
      <material name="blue"><color rgba="0.1 0.1 0.9 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="1.2 0.8 0.5"/></geometry>
    </collision>
    <inertial>
      <mass value="50"/>
      <inertia ixx="3.708333" ixy="0" ixz="0"
               iyy="7.041667" iyz="0"
               izz="8.666667"/>
    </inertial>
  </link>

  <!-- ===== КОЛЁСА (SDF: radius=0.2, length=0.08) ===== -->
  <!-- SDF pose relative_to body: (±0.40, ±0.44, -0.25), rpy=(-pi/2, 0, 0) -->

  <xacro:macro name="wheel" params="name xyz_str">
    <link name="${name}">
      <visual>
        <origin rpy="1.5707963 0 0"/>
        <geometry><cylinder radius="0.2" length="0.08"/></geometry>
        <material name="darkgray"><color rgba="0.15 0.15 0.15 1"/></material>
      </visual>
      <collision>
        <origin rpy="1.5707963 0 0"/>
        <geometry><cylinder radius="0.2" length="0.08"/></geometry>
      </collision>
      <inertial>
        <mass value="3"/>
        <inertia ixx="0.0316" ixy="0" ixz="0"
                 iyy="0.0316" iyz="0"
                 izz="0.06"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="${xyz_str}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="front_left_wheel"  xyz_str=" 0.40  0.44 -0.25"/>
  <xacro:wheel name="front_right_wheel" xyz_str=" 0.40 -0.44 -0.25"/>
  <xacro:wheel name="back_left_wheel"   xyz_str="-0.40  0.44 -0.25"/>
  <xacro:wheel name="back_right_wheel"  xyz_str="-0.40 -0.44 -0.25"/>

  <!-- ===== СТОЙКА КАМЕРЫ (SDF desk_for_depth: 0.08×0.08×0.7м) ===== -->
  <!-- pose relative_to body: (0.55, 0, 0.5) -->
  <link name="desk_for_depth">
    <visual>
      <geometry><box size="0.08 0.08 0.7"/></geometry>
      <material name="gray"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.1034" ixy="0" ixz="0"
               iyy="0.1034" iyz="0"
               izz="0.00267"/>
    </inertial>
  </link>
  <joint name="desk_for_depth_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="desk_for_depth"/>
    <origin xyz="0.55 0 0.5" rpy="0 0 0"/>
  </joint>

  <!-- ===== RGBD-КАМЕРА (SDF: pose relative_to desk_for_depth) ===== -->
  <!-- SDF: (0.05, 0, 0.33, 0, 0.872665, 0) — наклон вниз 50° -->
  <link name="RGBD_camera">
    <visual>
      <geometry><box size="0.05 0.1 0.04"/></geometry>
      <material name="black"><color rgba="0.05 0.05 0.05 1"/></material>
    </visual>
    <inertial>
      <mass value="0.145"/>
      <inertia ixx="0.0000604" ixy="0" ixz="0"
               iyy="0.0000604" iyz="0"
               izz="0.0000604"/>
    </inertial>
  </link>
  <joint name="RGBD_camera_joint" type="fixed">
    <parent link="desk_for_depth"/>
    <child  link="RGBD_camera"/>
    <!-- SDF pitch=0.872665 (наклон носом вниз) → в URDF rpy=(0, 0.872665, 0) -->
    <origin xyz="0.05 0 0.33" rpy="0 0.872665 0"/>
  </joint>

  <!-- ===== НАВИГАЦИОННАЯ КАМЕРА (SDF: pose relative_to body) ===== -->
  <!-- SDF: (0.6, 0, 0, 0, 0.0872665, 0) — небольшой наклон вниз 5° -->
  <link name="nav_camera">
    <visual>
      <geometry><box size="0.05 0.1 0.04"/></geometry>
      <material name="midgray"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <inertial>
      <mass value="0.145"/>
      <inertia ixx="0.0000604" ixy="0" ixz="0"
               iyy="0.0000604" iyz="0"
               izz="0.0000604"/>
    </inertial>
  </link>
  <joint name="nav_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="nav_camera"/>
    <origin xyz="0.6 0 0" rpy="0 0.0872665 0"/>
  </joint>

  <!-- ===== ЛИДАР (SDF: pose relative_to body: 0 0 0.32) ===== -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.055" length="0.07"/></geometry>
      <material name="lidar_black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0"
               iyy="0.0002" iyz="0"
               izz="0.0003"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 0.32" rpy="0 0 0"/>
  </joint>

</robot>

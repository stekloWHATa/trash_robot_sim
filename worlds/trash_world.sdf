        <visual name="filter"><pose>0.030 0 0 0 0 0</pose>
          <geometry><cylinder><radius>0.005</radius><length>0.012</length></cylinder></geometry>
          <material><ambient>0.90 0.45 0.10 1</ambient><diffuse>1.00 0.55 0.15 1</diffuse></material></visual>
        <collision name="c">
          <geometry><cylinder><radius>0.005</radius><length>0.065</length></cylinder></geometry></collision>
      </link></model>


    <!-- #10  (3, -3) Красная банка (вторая) -->
    <model name="can_red2">
      <static>false</static>
      <pose>3.0 -3.0 0.063 0 0 0.8</pose>
      <link name="link">
        <inertial><mass>0.015</mass>
          <inertia><ixx>0.00005</ixx><ixy>0</ixy><ixz>0</ixz>
